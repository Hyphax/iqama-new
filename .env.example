# ─── Iqama Squad Feature — Supabase Setup ────────────────────────────────────
#
# Squad feature ke liye Supabase chahiye (bilkul free hai).
#
# Setup steps:
#   1. https://supabase.com → "New project" banao (free tier)
#
#   2. SQL Editor mein ye query run karo:
#
#        create table if not exists squad_members (
#          user_code    text primary key,
#          display_name text not null,
#          prayers      jsonb not null default '{}',
#          streak       integer not null default 0,
#          updated_at   timestamptz default now()
#        );
#        alter table squad_members enable row level security;
#        create policy "public_read"   on squad_members for select using (true);
#        create policy "public_write"  on squad_members for insert with check (true);
#        create policy "public_update" on squad_members for update using (true);
#
#   3. Is file ko copy karke ".env" naam do:
#        cp .env.example .env
#
#   4. Neeche apni values daalo
#      (Supabase → Project Settings → API mein milegi)
#
# ─────────────────────────────────────────────────────────────────────────────

EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# NOTE: "EXPO_PUBLIC_" prefix zaroori hai —
# tabhi ye values Expo app mein accessible hongi.
# Ye anon key safe hai client-side pe (read-only RLS policies ke saath).
